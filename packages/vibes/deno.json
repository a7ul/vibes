{
  "name": "@vibesjs/vibes",
  "version": "0.1.0",
  "exports": "./mod.ts",
  "tasks": {
    "dev": "deno run --allow-all main.ts",
    "tui": "deno run --allow-all tui.ts",
    "test": "deno test --allow-all",
    "compile": "deno compile --allow-all --output vibes main.ts"
  },
  "compilerOptions": {
    "jsx": "react-jsx",
    "jsxImportSource": "react",
    "types": ["npm:@types/react@^19"]
  },
  "imports": {
    "@vibesjs/sdk": "../sdk/mod.ts",
    "zod": "npm:zod@^4",
    "@ai-sdk/anthropic": "npm:@ai-sdk/anthropic@^3",
    "@ai-sdk/openai": "npm:@ai-sdk/openai@^3",
    "@anthropic-ai/sandbox-runtime": "npm:@anthropic-ai/sandbox-runtime",
    "@std/path": "jsr:@std/path@^1",
    "@std/cli": "jsr:@std/cli@^1",
    "@std/assert": "jsr:@std/assert@^1.0.19",
    "ai/test": "npm:ai@^6/test",
    "react": "npm:react@^19",
    "react/jsx-runtime": "npm:react@^19/jsx-runtime",
    "ink": "npm:ink@^6",
    "ink-spinner": "npm:ink-spinner@^5",
    "ink-text-input": "npm:ink-text-input@^6",
    "ink-testing-library": "npm:ink-testing-library@^4"
  }
}
